# OpenAI (self-hosted: set OPENAI_BASE_URL; self-signed cert: OPENAI_CA_BUNDLE or OPENAI_SSL_VERIFY=false)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://your-llm.example.com/v1
# OPENAI_SSL_VERIFY=false
# OPENAI_CA_BUNDLE=/path/to/ca.pem

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/coach.db

# RAG
CHROMA_PERSIST_DIR=./data/chroma_db
CHUNK_SIZE=512
CHUNK_OVERLAP=50
SIMILARITY_TOP_K=5

# 应用
DEBUG=true
